# ─────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT VARIABLES — copy this file to .env and fill in your own values
# .env is gitignored and must NEVER be committed to source control
# ─────────────────────────────────────────────────────────────────────────────

# ── Frontend (Vite — VITE_ prefix exposes vars to the browser bundle) ─────────

# EmailJS — https://www.emailjs.com
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_CONTACT=your_contact_template_id
VITE_EMAILJS_TEMPLATE_REPLY=your_autoreply_template_id

# Google reCAPTCHA v2 — https://www.google.com/recaptcha
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# ── Backend (Netlify Functions — no VITE_ prefix, never sent to browser) ─────

# MongoDB Atlas connection string — https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_DATABASE=portfolio_cm

# Admin authentication
# Generate hash: node -e "const b=require('bcryptjs'); b.hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=your_bcrypt_hash_here
# Generate secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ADMIN_JWT_SECRET=your_64_char_random_secret_here

# Cloudinary image hosting — https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
